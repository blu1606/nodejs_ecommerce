  "item": [
    {
      "name": "Access",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response && response.metadata && response.metadata.tokens) {",
                  "    pm.collectionVariables.set(\"accessToken\", response.metadata.tokens.accessToken);",
                  "    pm.collectionVariables.set(\"refreshToken\", response.metadata.tokens.refreshToken);",
                  "    pm.collectionVariables.set(\"clientId\", response.metadata.shop._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Shop Pro Max\",\n    \"email\": \"shoppromax@gmail.com\",\n    \"password\": \"abc123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/shop/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "shop",
                "signup"
              ]
            }
          },
          "response": []
